DATABASE_URL=sqlite:///./bussola.db
SECRET_KEY=change-me-in-production-please-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Cole sua chave da Anthropic API para habilitar análise IA de pesquisas
# Obtenha em: https://console.anthropic.com/settings/keys
# Modelo usado: claude-haiku-4-5 (~R$0,01 por análise de pesquisa)
ANTHROPIC_API_KEY=

# Em produção, lista CSV dos domínios autorizados (ex: Vercel)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Setar 0 para desabilitar scheduler RSS/Câmara/Senado/Alertas (ex: testes)
ENABLE_SCHEDULERS=1
